{
  "cli": {
    "version": ">= 18.8.0",
    "appVersionSource": "local"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://finance.pm.sa/api/v1",
        "EXPO_PUBLIC_USE_MOCKS": "false"
      }
    },
    "production": {
      "autoIncrement": true
    }
  }
}